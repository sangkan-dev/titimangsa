{
  "name": "titimangsa",
  "version": "1.0.0",
  "description": "Indonesia holiday and business day API, curated from official public sources.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "format:check": "prettier --check .",
    "validate:data": "tsx scripts/validate.ts",
    "generate:data": "tsx scripts/generate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "test:watch": "vitest",
    "dev:api": "pnpm --filter @sangkan-dev/titimangsa-api dev",
    "deploy:api": "pnpm --filter @sangkan-dev/titimangsa-api deploy",
    "dev:docs": "pnpm --filter @sangkan-dev/titimangsa-docs dev",
    "build:docs": "pnpm --filter @sangkan-dev/titimangsa-docs build",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/node": "^25.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md,yml,yaml,css}": [
      "prettier --check"
    ]
  }
}
