{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sangkan.dev/titimangsa/schemas/draft.schema.json",
  "title": "Titimangsa Automation Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "year",
    "detectedAt",
    "status",
    "requiresReview",
    "generator",
    "source",
    "holidays"
  ],
  "properties": {
    "year": {
      "type": "integer",
      "minimum": 1900,
      "maximum": 9999
    },
    "detectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "const": "draft"
    },
    "requiresReview": {
      "type": "boolean",
      "const": true
    },
    "generator": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "publisher",
        "type",
        "official",
        "confidence"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "official": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "holidays": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "localName", "type", "confidence", "rawText"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "localName": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["national_holiday", "collective_leave", "unknown"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rawText": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
